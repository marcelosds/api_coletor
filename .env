## Server
PORT=3000
NODE_ENV=development

## JWT
JWT_SECRET=coletor-patrimonial-secret-key-2024
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

## CORS
# Use '*' para desenvolvimento local; ajuste para domínios específicos em produção
CORS_ORIGIN=*

## Database (SQLite)
# Caminho padrão já é ./data/database.sqlite; ajuste se necessário
DB_PATH=./data/database.sqlite

## Firebase Admin SDK
# Aponte para o arquivo de conta de serviço ou use o conteúdo inline abaixo.
# Esta opção usa o arquivo que já existe dentro de api/
FIREBASE_CREDENTIALS_PATH=./coletoroficial-firebase-adminsdk-fbsvc-b4c3260d39.json

# URL do Realtime Database/Firestore (se aplicável)
FIREBASE_DATABASE_URL=https://coletoroficial-default-rtdb.firebaseio.com

# Alternativa: conteúdo inline do JSON (NÃO recomendado em produção)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"coletoroficial","private_key_id":"<redacted>","private_key":"-----BEGIN PRIVATE KEY-----\n<redacted>\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@coletoroficial.iam.gserviceaccount.com","client_id":"<redacted>","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk%40coletoroficial.iam.gserviceaccount.com"}