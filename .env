# ==========================
# API – Variáveis de Ambiente
# ==========================

# Servidor
PORT=3000
NODE_ENV=development

# CORS
# Ajuste para a origem do seu app (Expo/produção)
CORS_ORIGIN=*

# Banco de Dados (SQLite)
# Caminho do arquivo .sqlite usado pela API
DB_PATH=./data/database.sqlite

# JWT (Tokens de autenticação da API)
# Troque por um segredo forte em produção
JWT_SECRET=coletor-patrimonial-secret-key-2024
# Prazo do token de acesso
JWT_EXPIRES_IN=24h
# Prazo do refresh token
JWT_REFRESH_EXPIRES_IN=7d

# Firebase Admin SDK (verificação de idToken / operações em usuários)
# Utilize UMA das opções de credenciais abaixo:

# 1) Caminho para o JSON do service account
# Ex.: C:\caminho\para\service-account.json ou ./coletoroficial-firebase-adminsdk-fbsvc-3916ca360e.json
FIREBASE_CREDENTIALS_PATH=./coletoroficial-firebase-adminsdk-fbsvc-3916ca360e.json

# 2) Conteúdo inline do JSON (copie o conteúdo inteiro, sem quebras de linha)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"coletoroficial", ...}

# 3) Variável padrão suportada pelo SDK
# GOOGLE_APPLICATION_CREDENTIALS=C:\caminho\para\service-account.json

# URL do Realtime Database (se aplicável)
FIREBASE_DATABASE_URL=https://coletoroficial-default-rtdb.firebaseio.com