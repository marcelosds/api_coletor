# Configurações do Servidor
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=coletor-patrimonial-secret-key-2024
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=*

# Database Configuration
DB_PATH=./data/database.sqlite

# Firebase Admin Credentials (não manter arquivo na pasta config)
# Use APENAS UMA das opções abaixo:

# 1) Caminho do arquivo de credenciais (service account)
# Exemplo Windows: C:\\segredo\\service-account.json
# Exemplo Linux/Mac: /etc/segredo/service-account.json
FIREBASE_CREDENTIALS_PATH=

# 2) Conteúdo inline do JSON de credenciais
# Coloque o JSON completo em uma única linha
# Exemplo: {"type":"service_account","project_id":"coletoroficial",...}
FIREBASE_SERVICE_ACCOUNT_JSON=

# URL do banco de dados Firebase (se aplicável)
FIREBASE_DATABASE_URL=https://coletoroficial-default-rtdb.firebaseio.com